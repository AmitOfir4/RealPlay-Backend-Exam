{
  "name": "realplay-tournaments",
  "version": "1.0.0",
  "description": "Tournaments module: bet ingestion, live Redis leaderboard, BullMQ finalization",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:api": "node dist/apps/api/src/main.js",
    "start:workers": "node dist/apps/workers/src/main.js",
    "dev:api": "ts-node apps/api/src/main.ts",
    "dev:workers": "ts-node apps/workers/src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "rebuild:leaderboard": "ts-node scripts/rebuild-leaderboard.ts",
    "test": "jest",
    "test:int": "jest --config test/jest-int.json --runInBand"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps",
      "<rootDir>/libs"
    ],
    "testMatch": [
      "**/*.spec.ts"
    ]
  }
}
